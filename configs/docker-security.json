{
  "version": "1.0",
  "security_profile": "enterprise",
  "description": "ASF Framework Docker security configuration for v3.2",
  "seccomp": "standard",
  "apparmor": "asf-profile",
  "security_opts": [
    "no-new-privileges:true",
    "seccomp:unconfined"
  ],
  "cap_drop": ["ALL"],
  "cap_add": ["NET_BIND_SERVICE", "CHOWN", "SETGID", "SETUID", "DAC_OVERRIDE"],
  "network_mode": "bridge",
  "privileged": false,
  "read_only_rootfs": false,
  "tmpfs": ["/tmp", "/var/run"],
  "log_driver": "json-file",
  "log_opts": {
    "max_size": "10m",
    "max_file": "3"
  },
  "healthcheck": {
    "test": ["CMD", "asf", "verify"],
    "interval": "30s",
    "timeout": "10s",
    "retries": 3
  },
  "resource_limits": {
    "memory": "2g",
    "cpus": "1.0",
    "pids_limit": 256
  }
}
