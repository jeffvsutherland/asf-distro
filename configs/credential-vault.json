{
  "version": "1.0",
  "description": "ASF Framework credential vault configuration",
  "vault_type": "platform_keychain",
  "credential_sources": {
    "primary": "platform_keychain",
    "fallback": ["env_var"],
    "forbidden": ["plaintext_files", "git_history", "docker_inspect"]
  },
  "policies": {
    "hardcoded_creds": {
      "action": "block_and_alert",
      "severity": "CRITICAL"
    },
    "env_var_leak": {
      "action": "mask_and_log",
      "severity": "HIGH"
    },
    "credential_in_git": {
      "action": "block_push_and_alert",
      "severity": "CRITICAL"
    }
  },
  "audit": {
    "log_all_access": true,
    "log_retention_days": 90,
    "alert_on_rotation": true
  },
  "rotation": {
    "auto_rotate": false,
    "reminder_days": 90,
    "platform": "openclaw_keychain"
  }
}
